mads 2.1.5 build 3 (21 Feb 22)
Source: plot.asm
     1 				; =====================================================================
     2 				; Plot.asm
     3 				;   Draw yellow pixels on the Atari 800XL in Graphics Mode 7
     4 				;   Uses CIO (Central I/O) to open the graphics mode, then writes
     5 				;   pixel data directly to screen RAM.
     6 				;
     7 				;   GR.7 screen properties:
     8 				;   - 160 pixels wide x 96 pixels tall (with text window: 80 rows)
     9 				;   - 4 colors using color registers
    10 				;   - Each byte contains 4 pixels (2 bits per pixel)
    11 				;   - 40 bytes per row x 80 rows = 3200 bytes of screen RAM
    12 				;   - Pixel value %01010101 ($55) = 4 yellow pixels using COLOR0
    13 				; =====================================================================
    14
    15
    16 				; Zero page variables
    17 = 0082			plotX   = $82       ; X coordinate (0-159)
    18 = 0083			plotY   = $83       ; Y coordinate (0-79)
    19 = 0084			temp    = $84       ; temporary storage for multiplication
    20 = 0085			scrptr_lo = $85     ; calculated screen address low byte
    21 = 0086			scrptr_hi = $86     ; calculated screen address high byte
    22
    23
    24 				; =====================================================================
    25 				; CIO (Central I/O) constants
    26 				; CIO is the Atari OS I/O system. We use it to open graphics mode.
    27 				; Each I/O channel uses an IOCB (I/O Control Block) — a fixed block
    28 				; of memory containing command, device, buffer address, and aux bytes.
    29 				; We use IOCB6 (base address $0360) for graphics.
    30 				; X register = $60 tells CIOV which IOCB to use (IOCB6).
    31 				; =====================================================================
    32 = E456			CIOV    = $E456     ; OS CIO entry point — call jsr CIOV to execute
    33 = 0342			ICCOM   = $0342     ; IOCB6 command register
    34 				                    ;   $03 = OPEN   (open a device)
    35 				                    ;   $0C = CLOSE  (close a device)
    36 = 0344			ICBAL   = $0344     ; IOCB6 buffer address low byte
    37 				                    ;   for OPEN: points to device name string "S:"
    38 = 0345			ICBAH   = $0345     ; IOCB6 buffer address high byte
    39 				                    ;   together with ICBAL forms 16-bit pointer to "S:"
    40 = 034A			ICAX1   = $034A     ; IOCB6 auxiliary byte 1
    41 				                    ;   for OPEN: $0C = read/write access mode
    42 = 034B			ICAX2   = $034B     ; IOCB6 auxiliary byte 2
    43 				                    ;   for OPEN: graphics mode number (7 = GR.7)
    44
    45 				; =====================================================================
    46 				; Screen RAM pointer
    47 				; After CIO opens GR.7, the OS stores the address of screen RAM
    48 				; in SAVMSC (two bytes). $58 = low byte, $59 = high byte.
    49 				; On our 800XL PAL system screen RAM ends up at $B060.
    50 				; =====================================================================
    51 = 0058			SAVMSC  = $58       ; zero page address — low byte of screen RAM address
    52 				                    ; $59 automatically contains the high byte
    53
    54 				; =====================================================================
    55 				; Attract mode constants
    56 				; The Atari OS has an attract mode that kicks in after inactivity
    57 				; to prevent screen burn-in. It does this by desaturating all colors
    58 				; making everything appear as shades of grey/blue.
    59 				; We must continuously reset these in our main loop to keep colors!
    60 				; =====================================================================
    61 = 004D			ATRACT  = $4D       ; attract mode counter — OS increments this each frame
    62 				                    ; when it reaches a threshold attract mode activates
    63 				                    ; we keep writing 0 to prevent it from activating
    64 = 004E			ATRMSK  = $4E       ; attract mode color mask
    65 				                    ; OS ANDs all colors with this value
    66 				                    ; $FE strips hue leaving only luminance (grey/blue)
    67 				                    ; $FF = full color (no masking) — what we want
    68
    69 				        org $2000                   ; place program at address $2000
    70
    71 				        .proc main
    72
    73 				; =====================================================================
    74 				; STEP 1: Close IOCB6
    75 				; Good practice to close before opening — ensures clean state.
    76 				; ON ENTRY: X must contain IOCB number × $10 ($60 for IOCB6)
    77 				; ON ENTRY: ICCOM must contain the command ($0C = CLOSE)
    78 				; ON EXIT:  IOCB6 is closed and ready to be reopened
    79 				; =====================================================================
    80 FFFF> 2000-2060> A2 60	        ldx #$60                    ; X = $60        (select IOCB6)
    81 2002 A9 0C		        lda #$0C                    ; A = $0C        (CLOSE command)
    82 2004 9D 42 03		        sta ICCOM,x                 ; ICCOM = $0C    (store command in IOCB6)
    83 2007 20 56 E4		        jsr CIOV                    ; CALL CIOV      (execute the close)
    84
    85 				; =====================================================================
    86 				; STEP 2: Open Graphics Mode 7
    87 				; Fills in all IOCB6 fields then calls CIOV to execute the open.
    88 				; CIO sets up the display list, allocates screen RAM, configures
    89 				; ANTIC — everything needed for graphics mode automatically.
    90 				; ON ENTRY: X must contain $60 (IOCB6)
    91 				; ON EXIT:  GR.7 screen is active, SAVMSC points to screen RAM
    92 				; =====================================================================
    93 200A A2 60		        ldx #$60                    ; X = $60        (select IOCB6)
    94 200C A9 03		        lda #$03                    ; A = $03        (OPEN command)
    95 200E 9D 42 03		        sta ICCOM,x                 ; ICCOM = $03    (store open command)
    96 2011 A9 5E		        lda #<scrname               ; A = low byte of "S:" string address
    97 2013 9D 44 03		        sta ICBAL,x                 ; ICBAL = low byte (tell CIO device name location)
    98 2016 A9 20		        lda #>scrname               ; A = high byte of "S:" string address
    99 2018 9D 45 03		        sta ICBAH,x                 ; ICBAH = high byte
   100 201B A9 07		        lda #$07                    ; A = $07        (graphics mode 7)
   101 201D 9D 4B 03		        sta ICAX2,x                 ; ICAX2 = $07    (store graphics mode number)
   102 2020 A9 0C		        lda #$0C                    ; A = $0C        (read/write access)
   103 2022 9D 4A 03		        sta ICAX1,x                 ; ICAX1 = $0C    (store access mode)
   104 2025 20 56 E4		        jsr CIOV                    ; CALL CIOV      (execute open — sets up entire graphics mode!)
   105
   106 				; =====================================================================
   107 				; STEP 3: Clear Screen RAM to black
   108 				; Screen RAM at $B060 may contain garbage from previous programs.
   109 				; We fill 256 bytes with $00 (black = all pixels off).
   110 				; Note: this only clears the first 256 bytes (one page) of screen RAM.
   111 				; Full screen RAM is 3200 bytes — we'd need a 16-bit loop for all of it.
   112 				; $00 = %00000000 = all 4 pixels in byte = background color (black)
   113 				; =====================================================================
   114
   115 2028 A5 58		        lda $58         ; A = memory[$58]  (low byte of screen RAM address)
   116 202A 85 80		        sta $80         ; store in zero page pointer low byte
   117 202C A5 59		        lda $59         ; A = memory[$59]  (high byte of screen RAM address)
   118 202E 85 81		        sta $81         ; store in zero page pointer high byte
   119
   120 2030 A0 00		        ldy #0          ; Y = 0
   121 2032			clearscreen:
   122 2032 A9 00		        lda #$00        ; A = $00
   123 2034 91 80		        sta ($80),y     ; write to memory[strptr + Y] instead of hardcoded $B060
   124 2036 C8			        iny
   125 2037 D0 F9		        bne clearscreen
   126
   127 				; =====================================================================
   128 				; STEP 4: Draw yellow pixels at lower right corner
   129 				; Screen RAM last byte is at $BCDF (row 79, byte 39)
   130 				; $55 = %01010101 = 4 pixels all using COLOR0 = yellow
   131 				; GR.7 uses color artifacting — adjacent bit pattern determines color
   132 				; %01 pixel value = COLOR0, but needs correct bit pattern for true color
   133 				; =====================================================================
   134 2039 A9 55		        lda #$55                    ; A = $55        (4 yellow pixels)
   135 				        
   136 				        
   137 203B A5 58		        lda $58         ; A = low byte of SAVMSC
   138 203D 18			        clc
   139 203E 69 7F		        adc #$7F        ; add low byte of offset $C7F
   140 2040 85 82		        sta $82         ; store result low byte (using $82 not $80!)
   141 2042 A5 59		        lda $59         ; A = high byte of SAVMSC
   142 2044 69 0C		        adc #$0C        ; add high byte of offset (carry included automatically!)
   143 2046 85 83		        sta $83         ; store result high byte
   144
   145 2048 A0 00		        ldy #0
   146 204A A9 55		        lda #$55        ; yellow pixels
   147 204C 91 82		        sta ($82),y     ; write to calculated lower right address
   148
   149 				; =====================================================================
   150 				; MAIN LOOP
   151 				; We must continuously reset attract mode every loop iteration
   152 				; otherwise the OS VBI will desaturate our colors within seconds.
   153 				; We also continuously write our yellow color to COLOR0 shadow register
   154 				; to ensure it stays yellow despite OS interference.
   155 				; =====================================================================
   156 204E			stop:
   157 204E A9 00 85 4D		        mva #0    ATRACT            ; memory[$4D] = 0     (reset attract counter)
   158 2052 A9 FF 85 4E		        mva #$FF  ATRMSK            ; memory[$4E] = $FF   (full color mask — no desaturation)
   159 2056 A9 1E 8D C4 02	        mva #$1E  $02C4             ; memory[$02C4] = $1E (COLOR0 shadow = bright yellow)
   160 205B 4C 4E 20		        jmp stop                    ; GOTO stop           (loop forever)
   161
   162 				        .endp                       ; end of main procedure
   163
   164 				; =====================================================================
   165 				; DATA
   166 				; =====================================================================
   167 205E 53 3A 9B		scrname .byte 'S:',$9B             ; device name string for CIO OPEN
   168 				                                    ; 'S:' = screen device
   169 				                                    ; $9B  = ATASCII end-of-line terminator
   170
   171 				; =====================================================================
   172 				; ENTRY POINT
   173 				; =====================================================================
   174 02E0-02E1> 00 20		        run main                    ; set Atari run address to main
   175 				                                    ; (auto-execute when program loads)
