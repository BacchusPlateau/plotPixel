mads 2.1.5 build 3 (21 Feb 22)
Source: plot.asm
     1 				; Plot.asm
     2 = E456			CIOV    = $E456     ; OS CIO entry point
     3 = 0342			ICCOM   = $0342     ; IOCB base command  
     4 = 0344			ICBAL   = $0344     ; buffer address low
     5 = 0345			ICBAH   = $0345     ; buffer address high
     6 = 034A			ICAX1   = $034A     ; aux byte 1
     7 = 034B			ICAX2   = $034B     ; aux byte 2
     8 = 0058			SAVMSC  = $58       ; zero page — screen RAM address low
     9 				                    ; $59 = high byte
    10
    11 				        org $2000
    12
    13 				        .proc main
    14
    15 				        ; close IOCB6 first (good practice)
    16 FFFF> 2000-204A> A2 60	        ldx #$60            ; IOCB6
    17 2002 A9 0C		        lda #$0C            ; CLOSE command
    18 2004 9D 42 03		        sta ICCOM,x
    19 2007 20 56 E4		        jsr CIOV
    20
    21 				        ; open graphics mode 7 on IOCB6
    22 200A A2 60		        ldx #$60            ; IOCB6
    23 200C A9 03		        lda #$03            ; OPEN command
    24 200E 9D 42 03		        sta ICCOM,x
    25 2011 A9 48		        lda #<scrname       ; point to "S:"
    26 2013 9D 44 03		        sta ICBAL,x
    27 2016 A9 20		        lda #>scrname
    28 2018 9D 45 03		        sta ICBAH,x
    29 201B A9 07		        lda #$07            ; graphics 7 with text window
    30 201D 9D 4B 03		        sta ICAX2,x
    31 2020 A9 0C		        lda #$0C            ; read/write
    32 2022 9D 4A 03		        sta ICAX1,x
    33 2025 20 56 E4		        jsr CIOV
    34
    35 				        ; set yellow color
    36 2028 A9 1E		        lda #$1E
    37 202A 8D C5 02		        sta $02C5           ; COLOR1 shadow register
    38
    39 				        ; find screen RAM address from SAVMSC
    40 				        ; lower right pixel is at last byte of screen RAM
    41 				        ; GR.7 = 160x96, 40 bytes per row, 96 rows = 3840 bytes
    42 				        ; last byte = SAVMSC + 3839 = SAVMSC + $EFF
    43
    44 202D A9 1E		        lda #$1E
    45 202F 8D C4 02		        sta $02C4           ; COLOR0 shadow — for pixel value $01
    46
    47 2032 A5 58		        lda $58             ; low byte of screen RAM address
    48 2034 18			        clc
    49 2035 69 FF		        adc #$FF            ; add low byte of offset $EFF
    50 2037 85 80		        sta $80             ; store in zero page pointer
    51 2039 A5 59		        lda $59             ; high byte
    52 203B 69 0E		        adc #$0E            ; add high byte of offset $EFF
    53 203D 85 81		        sta $81             ; store high byte
    54
    55 203F A0 00		        ldy #0
    56 2041 A9 01		        lda #$01            ; color 1 pixel value
    57 2043 91 80		        sta ($80),y         ; write pixel!
    58
    59 2045			stop:
    60 2045 4C 45 20		        jmp stop
    61
    62 				        .endp
    63
    64 2048 53 3A 9B		scrname .byte 'S:',$9B      ; device name with end of line marker
    65
    66 02E0-02E1> 00 20		        run main
