mads 2.1.5 build 3 (21 Feb 22)
Source: plot.asm
     1 				; Plot.asm
     2 				;   Draw a single yellow pixel on the Atari 800XL
     3 				;   Using CIO to open GR.7 then writing directly to screen RAM
     4
     5 = E456			CIOV    = $E456     ; OS CIO entry point
     6 = 0342			ICCOM   = $0342     ; IOCB base command
     7 = 0344			ICBAL   = $0344     ; buffer address low
     8 = 0345			ICBAH   = $0345     ; buffer address high
     9 = 034A			ICAX1   = $034A     ; aux byte 1
    10 = 034B			ICAX2   = $034B     ; aux byte 2
    11 = 0058			SAVMSC  = $58       ; zero page — screen RAM address low ($59 = high byte)
    12 = 004D			ATRACT  = $4D       ; attract mode counter — keep at 0 to prevent color washout
    13 = 004E			ATRMSK  = $4E       ; attract mode color mask
    14
    15 				        org $2000
    16
    17 				        .proc main
    18
    19 				        ; close IOCB6 first (good practice)
    20 FFFF> 2000-2049> A2 60	        ldx #$60            ; IOCB6
    21 2002 A9 0C		        lda #$0C            ; CLOSE command
    22 2004 9D 42 03		        sta ICCOM,x
    23 2007 20 56 E4		        jsr CIOV
    24
    25 				        ; open graphics mode 7 with text window on IOCB6
    26 200A A2 60		        ldx #$60            ; IOCB6
    27 200C A9 03		        lda #$03            ; OPEN command
    28 200E 9D 42 03		        sta ICCOM,x
    29 2011 A9 47		        lda #<scrname       ; point to device name "S:"
    30 2013 9D 44 03		        sta ICBAL,x
    31 2016 A9 20		        lda #>scrname
    32 2018 9D 45 03		        sta ICBAH,x
    33 201B A9 07		        lda #$07            ; graphics mode 7 with text window
    34 201D 9D 4B 03		        sta ICAX2,x
    35 2020 A9 0C		        lda #$0C            ; read/write access
    36 2022 9D 4A 03		        sta ICAX1,x
    37 2025 20 56 E4		        jsr CIOV            ; call OS CIO — sets up display list and screen RAM
    38
    39 				        ; fill screen with black
    40 2028 A2 00		        ldx #0
    41 202A			clearscreen:
    42 202A A9 00		        lda #$00
    43 202C 9D 60 B0		        sta $B060,x
    44 202F E8			        inx
    45 2030 D0 F8		        bne clearscreen
    46
    47 2032 A9 55		        lda #$55
    48 2034 8D DF BC		        sta $BCDF
    49
    50 2037			stop:
    51 2037 A9 00 85 4D		        mva #0 ATRACT
    52 203B A9 FF 85 4E		        mva #$FF ATRMSK
    53 203F A9 1E 8D C4 02	        mva #$1E $02C4
    54 2044 4C 37 20		        jmp stop
    55
    56 				        .endp
    57
    58 2047 53 3A 9B		scrname .byte 'S:',$9B      ; device name with end of line marker
    59
    60 02E0-02E1> 00 20		        run main
